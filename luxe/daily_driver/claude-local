#!/usr/bin/env bash
# claude-local — launch `claude` pointed at the local qwen-coder stack.
#
# Health-checks the LiteLLM bridge first. If it's down, offers to start the
# launchd agents, fall back to cloud Claude, or abort.
#
# Install: copy/symlink into a directory on your PATH (e.g. ~/.local/bin).

set -eu

BRIDGE_URL="${LUXE_BRIDGE_URL:-http://127.0.0.1:4000}"
MLX_URL="${LUXE_MLX_URL:-http://127.0.0.1:8088}"
MLX_LABEL="com.luxe.mlx"
LITELLM_LABEL="com.luxe.litellm"
READY_TIMEOUT_S="${LUXE_READY_TIMEOUT_S:-60}"

is_up() {
    curl -sfL --max-time 3 "$1/v1/models" >/dev/null 2>&1
}

wait_for_ready() {
    local elapsed=0
    while ! is_up "$BRIDGE_URL"; do
        if [ "$elapsed" -ge "$READY_TIMEOUT_S" ]; then
            return 1
        fi
        sleep 2
        elapsed=$((elapsed + 2))
        printf "."
    done
    echo " ready."
}

start_agents() {
    local uid
    uid="$(id -u)"
    echo "kickstarting launchd agents…"
    # `launchctl kickstart -k` restarts if already loaded.
    launchctl kickstart -k "gui/${uid}/${MLX_LABEL}" 2>/dev/null || \
        echo "  (mlx agent not installed — see daily_driver/install.sh)"
    launchctl kickstart -k "gui/${uid}/${LITELLM_LABEL}" 2>/dev/null || \
        echo "  (litellm agent not installed — see daily_driver/install.sh)"
}

fall_back_to_cloud() {
    echo "falling back to cloud Claude (unsetting ANTHROPIC_BASE_URL for this session)…"
    unset ANTHROPIC_BASE_URL
    unset ANTHROPIC_AUTH_TOKEN
    exec claude "$@"
}

if is_up "$BRIDGE_URL"; then
    exec claude "$@"
fi

echo ""
echo "local model bridge at $BRIDGE_URL is not responding."
echo "  mlx server ($MLX_URL): $(is_up "$MLX_URL" && echo up || echo down)"
echo ""
echo "options:"
echo "  [s] start servers + wait for health"
echo "  [c] fall back to cloud Claude (uses your ANTHROPIC_API_KEY)"
echo "  [a] abort"
printf "choice: "
read -r choice

case "$choice" in
    s|S)
        start_agents
        echo -n "waiting for bridge to come up (up to ${READY_TIMEOUT_S}s)"
        if wait_for_ready; then
            exec claude "$@"
        else
            echo ""
            echo "bridge did not come up in time. check logs:"
            echo "  ~/Library/Logs/luxe/mlx.err.log"
            echo "  ~/Library/Logs/luxe/litellm.err.log"
            exit 1
        fi
        ;;
    c|C)
        fall_back_to_cloud "$@"
        ;;
    *)
        echo "aborting."
        exit 1
        ;;
esac
