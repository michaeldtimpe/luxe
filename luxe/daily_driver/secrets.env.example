# luxe local secrets — auto-loaded into os.environ at REPL/CLI startup.
#
# Copy this file to ~/.luxe/secrets.env and fill in your real keys.
# Format: shell-style KEY=VALUE per line, # for comments. Quotes are
# optional; outer single/double quotes are stripped.
#
# Existing values in the shell environment ALWAYS win. So:
#   - `OMLX_API_KEY=foo luxe`     overrides the file for this run only
#   - `export OMLX_API_KEY=foo`   in your .zshrc wins permanently
#
# This file is local-only. ~/.luxe/ is gitignored at the repo root, but
# never copy this elsewhere with real values populated.
#
# Suggested install:
#   mkdir -p ~/.luxe
#   cp luxe/daily_driver/secrets.env.example ~/.luxe/secrets.env
#   chmod 600 ~/.luxe/secrets.env
#   $EDITOR ~/.luxe/secrets.env

# oMLX bearer token. Required for the code/review/refactor agents
# (which serve through oMLX on http://127.0.0.1:8000). Grab it from
# the oMLX admin dashboard: open http://127.0.0.1:8000/admin and the
# auto-login flow surfaces the key.
# OMLX_API_KEY=omlx-xxxxxxxxxxxxxxxx

# LM Studio bearer token. ONLY needed if you've enabled auth in LM
# Studio's Developer page → Server Settings → Manage Tokens. By
# default auth is OFF and you can leave this unset. If you do set
# auth, this is LM Studio's official env var name (LMSTUDIO_API_KEY
# also accepted as a fallback for backward compat).
# LM_API_TOKEN=lms-xxxxxxxxxxxxxxxx

# Override the default oMLX base URL if you've moved the daemon to a
# non-standard port (default 8000).
# LUXE_BACKEND_OVERRIDE_URL=http://127.0.0.1:8001

# Restrict which hosts the browser tool will navigate to. Defaults to
# a small set of well-known docs/dev sites — see
# luxe/cli/tools/browser.py:DEFAULT_BROWSER_ALLOWLIST. Comma-separated
# fnmatch patterns (no spaces).
# LUXE_BROWSER_ALLOWLIST=github.com,*.github.com,docs.python.org

# TTL for backend.py's parameter-size + context-length caches.
# Lower = picks up `ollama pull` updates faster; higher = fewer probes.
# LUXE_CACHE_TTL_S=300
