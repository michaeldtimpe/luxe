# Claude Code local state (settings, plan files, scheduled-task locks)
.claude/

# Local repo clones (cloned by `luxe maintain <url>`)
local-cache/

# Run/benchmark artifacts kept locally unless explicitly tracked
runs/
acceptance/
results/**/*.log
results/**/*.tmp
results/**/*.partial

# Uv / pip local state
.uv/

# Sibling projects in this workspace that aren't part of luxe
/ecliptic/
/warrens/
