# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual envs
.venv/
venv/
env/

# IDE / editor
.idea/
.vscode/
*.swp

# OS
.DS_Store

# Secrets — never commit
.env
.env.*
!.env.example

# Big local artifacts
luxe/models/
luxe/.venv/

# Personal repo clones + ingested commit corpus — contains the user's
# own private code; never push these anywhere.
luxe/personal_eval/cache/
luxe/personal_eval/corpus/

# Per-run evaluation artifacts. Generic model evals under luxe_eval/
# (general, research, writing) are kept; everything else is local run
# state or contains personal-repo analysis and stays local.
luxe/results/runs/
luxe/results/server_logs/
luxe/results/luxe_eval/code_analysis/

# Overnight autonomous-run output. Per-phase logs can be large and
# contain repo content from external clones (elara, never-say-yes,
# neon-rain). Distill findings to LESSONS.md or COMPOSITE_VERDICT.md
# by hand if you want them committed.
luxe/results/overnight_*/

# Belt-and-suspenders for luxe/results/: tracked outputs are intentional
# (REPORT.{csv,md}, VERDICT.{csv,md}, history.jsonl, eval markdown).
# Anything ephemeral — sweep logs, in-flight bench artifacts, replay
# fixtures regenerated each run — should not land in git even if
# scripts drop them outside the directories already ignored above.
luxe/results/**/*.log
luxe/results/**/*.tmp
luxe/results/**/*.partial
luxe/results/**/replay_inputs/*
!luxe/results/**/replay_inputs/.gitkeep

# Luxe-generated images (may include personal prompts / subjects)
luxe-images/

# Local session history
.luxe/

# Claude Code local state (settings, plan files, scheduled-task locks)
.claude/

# Stray results dir created when scripts are run from inside scripts/
# instead of from the project root. The real outputs live in
# luxe/results/runs/ and luxe/results/server_logs/.
luxe/scripts/results/

# Uv / pip local state
.uv/

# Local clones pulled in by `/review` and `/refactor`. These target
# external repos the user happens to be analyzing; their source of
# truth is elsewhere. Add new subdirectories here when /review clones
# a new target into the cwd.
/ecliptic/
/luxe/zoleb/
/luxe/elara/
/luxe/never-say-yes/
/luxe/neon-rain/

# Personal writing outside any tracked project (story drafts, outlines).
/warrens/
