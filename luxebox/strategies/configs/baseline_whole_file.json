{
  "name": "baseline_whole_file",
  "description": "Baseline retrieval, whole-file output. Tests whether switching off unified diffs recovers runs that lose to hunk-header errors.",
  "stages": [
    { "id": "preprocess", "enabled": false },
    { "id": "index", "enabled": true, "params": { "method": "text_files" } },
    { "id": "retrieve", "enabled": true, "params": { "method": "keyword_topk", "top_k_files": 12 } },
    { "id": "compress", "enabled": false },
    { "id": "prompt_assembly", "enabled": true, "params": { "output_format": "whole_file" } }
  ]
}
