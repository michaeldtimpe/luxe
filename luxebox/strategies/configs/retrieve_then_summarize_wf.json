{
  "name": "retrieve_then_summarize_wf",
  "description": "Keyword retrieval + LLM-summarised context. First real use of LLM-driven compression.",
  "stages": [
    { "id": "preprocess", "enabled": false },
    { "id": "index", "enabled": true, "params": { "method": "text_files" } },
    { "id": "retrieve", "enabled": true, "params": { "method": "keyword_topk", "top_k_files": 5 } },
    { "id": "compress", "enabled": true, "params": { "method": "summarize", "max_tokens_per_file": 160 } },
    { "id": "prompt_assembly", "enabled": true, "params": { "output_format": "whole_file" } }
  ]
}
